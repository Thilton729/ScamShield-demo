# Demo mode: set to "true" to use mock responses (no API keys required)
DEMO_MODE=true

# Backend URL (used by Streamlit to call the API)
# In Codespaces, use the forwarded port, e.g. http://localhost:8000
BACKEND_URL=http://localhost:8000

# Optional: for live AI (when DEMO_MODE=false)
# OPENAI_API_KEY=sk-...
